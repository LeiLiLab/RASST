u548c<t>\u5e8f\u5217</t>\u957f\u5ea6\uff0c\u4ee5\u53ca<t>\u8868\u793a</t>\u7684\u7ef4\u5ea6\u3002\u540c\u6837\u5730\uff0c\u5728<t>\u89e3\u7801\u5668</t>\u4ea4\u53c9<t>\u6ce8\u610f\u529b</t>\u4e2d\uff0c\u5982\u53f3\u4fa7\u56fe\u6240\u793a\uff0c\u552f\u4e00\u7684\u533a\u522b\u662f<t>\u76ee\u6807</t><t>\u4ee4\u724c</t>\u4f1a\u5173\u6ce8<t>\u8f93\u5165</t><t>\u4ee4\u724c</t>\u3002\u8fd9\u4e00\u70b9\u4e5f\u53ef\u4ee5\u4ece\u8fd9\u4e2a\u516c\u5f0f\u4e2d\u770b\u51fa\u3002<t>BLEU\u5206\u6570</t>\u4ee3\u8868\u4e86\u5fc5\u987b\u8ba1\u7b97\u7684<t>\u5173\u7cfb</t>\u3002\u5728\u5168<t>\u6ce8\u610f\u529b</t>\u7684\u60c5\u51b5\u4e0b\uff0c\u6211\u4eec\u9700\u8981\u8ba1\u7b97<t>\u8f93\u5165</t><t>\u5e8f\u5217</t>\u4e2d\u6bcf\u4e00\u5bf9<t>\u5173\u7cfb</t>\u3002\u73b0\u5728\u6211\u4eec\u6765\u770b\u770b\u5f53<t>\u7f16\u7801\u5668</t>\u6309\u5757\u5904\u7406\u65f6\u4f1a\u53d1\u751f\u4ec0\u4e48\uff0c\u5b83\u901a\u8fc7\u9650\u5236<t>\u4ee4\u724c</t>\u4e4b\u95f4\u7684\u8fde\u63a5\u6765\u5de5\u4f5c\uff0c\u4f7f\u5f97<t>\u4ee4\u724c</t>\u53ea\u80fd\u770b\u5230\u9644\u8fd1\u7684\u5176\u4ed6<t>\u4ee4\u724c</t>\u3002<t>\u6587\u672c</t>\u6309\u5757\u8bfb\u53d6\uff0c\u8fd9\u53ef\u4ee5\u5927\u5927\u51cf\u5c11<t>\u8ba1\u7b97</t>\u91cf\u548c<t>\u7f16\u7801\u5668</t>\u7aef\u7684<t>\u8ba1\u7b97</t>\u91cf\uff0c\u4f46\u5e76\u4e0d\u4f1a\u6539\u5584<t>\u89e3\u7801\u5668</t>\u4ea4\u53c9<t>\u6ce8\u610f\u529b</t>\uff0c\u56e0\u4e3a\u6bcf\u4e2a<t>\u8f93\u5165</t>\u4ee4\u724c\u90fd\u4f1a\u4f20\u9012\u7ed9<t>\u89e3\u7801\u5668</t>\u3002\u8fd9\u79cd\u65b9\u6cd5\u901a\u5e38\u88ab\u79f0\u4e3a<t>\u89e3\u7801\u5668</t>\u878d\u5408\u3002\u8fd9\u91cc\u7684\u6539\u8fdb\u53ef\u4ee5\u7406\u89e3\u4e3a\u6539\u53d8\u4e86<t>\u4f9d\u8d56\u5173\u7cfb</t>\uff0c\u5c06N\u66ff\u6362\u4e3a\u53e6\u4e00\u4e2a\u5e38\u6570M\uff0cM\u4ee3\u8868\u5757\u5927\u5c0f\u3002\u6211\u4eec\u7684\u5173\u952e\u89c2\u5bdf\u662f\uff0c\u5927\u591a\u6570<t>\u4ee4\u724c</t>\u5bf9\u4e8e\u5404\u79cd<t>\u4efb\u52a1</t>\u6765\u8bf4\u90fd\u662f\u76f8\u5173\u7684\uff0c\u51e0\u4e4e\u53ef\u4ee5\u5b8c\u5168\u5ffd\u7565\u4e0d\u8ba1\u3002\u5e7b\u706f\u7247\u4e0a\u7ed9\u51fa\u4e86\u4e00\u4e2a\u4f8b\u5b50\u3002\u6211\u4eec\u53ea\u5173\u6ce8<t>\u8f93\u5165</t>\u7684\u4e00\u90e8\u5206\uff0c\u8fd9\u4e9b\u90e8\u5206\u4e0e\u671f\u671b\u7684\u8f93\u51fa\u76f8\u5173\u3002\u5bf9\u4e8e\u4e00\u4e2a\u4f8b\u5b50\uff0c\u53ef\u4ee5\u53ea\u9605\u8bfb\u4e00\u6b21\u6587\u7ae0\uff0c\u6807\u8bb0\u51fa\u6700\u91cd\u8981\u7684\u90e8\u5206\uff0c\u7136\u540e\u57fa\u4e8e\u8fd9\u4e9b\u90e8\u5206\u4ece\u4e2d\u95f4\u9636\u6bb5\u751f\u6210\u6458\u8981\u3002\u6807\u8bb0\u548c\u51b3\u5b9a\u5f53\u524d<t>\u4ee4\u724c</t>\u662f\u5426\u5bf9\u751f\u6210\u6458\u8981\u81f3\u5173\u91cd\u8981\u6240\u4ed8\u51fa\u7684\u4ee3\u4ef7\u662f\u4f4e\u5ec9\u4e14\u4ec5\u53d6\u51b3\u4e8e<t>\u4ee4\u724c</t><t>\u8868\u793a</t>\u7684\u3002<t>\u4ee4\u724c</t>\u7684\u6c60\u5316\u662f\u53ef\u80fd\u7684\u3002\u8fd9\u5f97\u76ca\u4e8e\u6211\u4eec\u7684Top-K\u7b97\u5b50\uff0c\u5176\u6210\u672c\u81ea\u7136\u53ef\u5ffd\u7565\u4e0d\u8ba1\u3002\u4ece\u7f29\u77ed\u7684<t>\u8f93\u5165</t>\u751f\u6210\u6458\u8981\u7684\u6210\u672c\u4e5f\u8fdc\u4f4e\u4e8e<t>\u6a21\u578b</t>\u4e2d\u8003\u8651\u6574\u4e2a<t>\u8f93\u5165</t>\u65f6\u7684\u60c5\u51b5\u3002\u4f46\u8fd9\u91cc\u6709\u4e00\u4e2a<t>\u95ee\u9898</t>\uff1a\u5982\u4f55\u9009\u62e9\u91cd\u8981<t>\u4ee4\u724c</t>\u5e76\u5c06<t>\u68af\u5ea6</t>\u53cd\u5411\u4f20\u64ad\u5230\u9009\u62e9\u64cd\u4f5c\uff1f\u6211\u4eec\u89e3\u51b3\u7684\u5173\u952e\u5e95\u5c42<t>\u95ee\u9898</t>\u662f\u63d0\u51fa\u4e00\u79cd\u53ef\u8bad\u7ec3\u7684\u9009\u62e9\u673a\u5236\u3002\u8fd9\u79cd\u673a\u5236\u80fd\u591f\u5141\u8bb8<t>\u68af\u5ea6</t>\u5728<t>\u8bad\u7ec3</t>\u8fc7\u7a0b\u4e2d\u53cd\u5411\u4f20\u64ad\uff0c\u4ece\u800c\u4f7f\u7f51\u7edc\u80fd\u591f\u5b66\u4e60\u9009\u62e9\u6700\u91cd\u8981\u7684<t>\u4ee4\u724c</t>\u3002\u66f4\u5177\u4f53\u5730\u8bf4\uff0c\u7ed9\u5b9a\u4e00\u4e9b<t>\u5d4c\u5165</t>\u5411\u91cf\uff0c\u8fd9\u4e9b\u5411\u91cf\u6765\u81ea\u4e00\u4e2a\u7b80\u5355\u7684\u7ebf\u6027\u5c42\uff0c<t>\u4efb\u52a1</t>\u662f\u8fd4\u56de\u5f97\u5206\u6700\u9ad8\u7684<t>\u5d4c\u5165</t>\u5411\u91cf\u3002\u9996\u5148\uff0c<t>\u5e8f\u5217</t>\u88ab\u91cd\u65b0\u6392\u5217\uff0c\u4ee5\u4fbf\u5f97\u5206\u8f83\u9ad8\u7684<t>\u5411\u91cf</t>\u4e0e\u5f97\u5206\u8f83\u4f4e\u7684<t>\u5411\u91cf</t>\u914d\u5bf9\u3002\u63a5\u4e0b\u6765\uff0c<t>\u6743\u91cd</t>\u88ab\u901a\u8fc7\u5728\u5f97\u5206\u4e0a\u5e94\u7528\u589e\u5f3a\u7684softmax\u8ba1\u7b97\u5f97\u51fa\u3002\u6bcf\u8f6e\u6dd8\u6c70\u8d5b\u540e\uff0c\u90fd\u4f1a\u751f\u6210\u65b0\u7684<t>\u5411\u91cf</t>\u548c\u5f97\u5206\u3002\u5b83\u4eec\u4f5c\u4e3a\u8fd9\u4e9b\u914d\u5bf9\u7684<t>\u7ebf\u6027</t>\u7ec4\u5408\uff0c\u5e76\u4e58\u4ee5\u76f8\u5e94\u7684<t>\u6743\u91cd</t>\u3002\u7b80\u800c\u8a00\u4e4b\uff0c\u6211\u4eec\u901a\u8fc7\u6267\u884c\u8f6f<t>max</t>\u64cd\u4f5c\uff0c\u5c06\u5b83\u4eec\u8fdb\u884c<t>\u7ebf\u6027</t>\u7ec4\u5408\uff0c\u4ee5\u8ba1\u7b97\u5f97\u5206\u3002\u5728\u7ec4\u5408\u4e24\u4e2a<t>\u4ee4\u724c</t>\u65f6\uff0c\u4e00\u4e9b\u566a\u58f0\u53ef\u80fd\u88ab\u5f15\u5165\u3002\u4f46\u8fd9\u4e5f\u6709\u52a9\u4e8e<t>\u68af\u5ea6</t>\u7684\u4f20\u64ad\u5230\u6240\u6709<t>\u8f93\u5165</t><t>\u5d4c\u5165</t>\u3002\u7b80\u800c\u8a00\u4e4b\uff0c\u4e00\u4e2a\u53ef\u8bad\u7ec3\u7684top-k\u6211\u4eec<t>\u63d0\u51fa</t>\u7684\u65b9\u6cd5\u57fa\u4e8e\u7c7b\u4f3c\u9526\u6807\u8d5b\u7684\u8f6f\u9009\u62e9\uff0c\u5728\u6bcf\u4e00\u6b65\u90fd\u8fdb\u884c\u64cd\u4f5c\u3002\u4ece\u53e6\u4e00\u4e2a\u89d2\u5ea6\u6765\u770b\uff0c<t>\u8868\u793a</t>\u6c60\u5316\u9075\u5faa\u4e86\u7f16\u7801\u5668\u5c42\u3002\u9996\u5148\uff0c\u5bf9\u6bcf\u4e2a<t>\u8868\u793a</t>\u8fdb\u884c\u6253\u5206\uff0c\u7136\u540e\u4ec5\u4fdd\u7559\u5f97\u5206\u6700\u9ad8\u7684\u90a3\u4e9b<t>\u8868\u793a</t>\u4f20\u9012\u7ed9\u4e0b\u4e00\u5c42\u3002<t>\u7f16\u7801</t>\u53ef\u4ee5\u50cf\u6807\u51c6<t>\u8f6c\u6362\u5668</t>\u67b6\u6784\u90a3\u6837\uff0c\u5bf9\u5b8c\u6574\u957f\u5ea6\u7684<t>\u8f93\u5165</t>\u8fdb\u884c\u5904\u7406\u3002\u7136\u800c\uff0c\u4e5f\u53ef\u4ee5\u5904\u7406\u56fa\u5b9a\u957f\u5ea6\u7684<t>\u6587\u672c</t>\u5757\u3002\u7136\u540e\u5168\u5c40\u9009\u62e9\u6700\u4f73<t>\u8868\u793a</t>\u3002\u8fd9\u91cc\u662f\u4e00\u4e2a<t>\u8868\u793a</t>\u6c60\u5316\u7684\u4f8b\u5b50\u3002\u5728<t>\u7f16\u7801\u5668</t>\u4e4b\u540e\u5f15\u5165\u3002\u8fd9\u76f4\u63a5\u5f71\u54cd\u4e86\u4ea4\u53c9<t>\u6ce8\u610f\u529b</t>\u7684\u8ba1\u7b97\uff0c\u56e0\u4e3a\u6ce8\u610f\u529b\u7684\u8ba1\u7b97\u4e0d\u4ec5\u53d6\u51b3\u4e8e<t>\u8f93\u5165</t>\u957f\u5ea6\uff0c\u8fd8\u4e0e\u5e38\u6570k\u6709\u5173\u3002k\u4ee3\u8868\u6c60\u5316\u540e\u7684\u957f\u5ea6\u3002\u8fd9\u4e2a\u5e38\u6570\u51b3\u5b9a\u4e86\u9009\u62e9\u5e76\u4f20\u9012\u7ed9<t>\u89e3\u7801\u5668</t>\u7684<t>\u8868\u793a</t>\u6570\u91cf\u3002\u4ece\u8f83\u77ed\u7684<t>\u6587\u672c</t>\u751f\u6210\u6458\u8981\u8981\u6bd4\u4e4b\u524d\u7684\u65b9\u6cd5\u4fbf\u5b9c\u5f97\u591a\uff0c\u56e0\u4e3a<t>\u5e8f\u5217</t>\u957f\u5ea6\u53ef\u4ee5\u5927\u5e45\u7f29\u77ed\uff0c\u4f8b\u5982\uff0c\u6211\u4eec\u6210\u529f\u4f7f\u7528\u4e86k\u503c\u4e3a16\uff0c\u751a\u81f360\u500d\u4e8e\u539f\u59cb\u957f\u5ea6\u7684\u60c5\u51b5\u3002\u8fd9\u6bd4\u6211\u4eec\u5b9e\u9a8c\u4e2d\u7684n\u503c\u5c0f\u5f97\u591a\u3002\u8bf7\u6ce8\u610f\uff0c<t>\u8868\u793a</t>\u6c60\u5316\u5bf9\u5757\u7ea7<t>\u7f16\u7801</t>\u548c<t>\u6ce8\u610f\u529b</t>\u7684\u6709\u76ca\u5f71\u54cd\u662f\u6301\u7eed\u7684\u3002\u8bf7\u6ce8\u610f\uff0c\u8ba1\u7b97<t>\u6ce8\u610f\u529b</t>\u7684\u5f00\u9500\u53d6\u51b3\u4e8e<t>\u8f93\u5165</t>\u957f\u5ea6\u7684\u5e73\u65b9\u3002\u51cf\u5c11<t>\u8f93\u5165</t>\u957f\u5ea6\u53ef\u4ee5\u663e\u8457\u964d\u4f4e\u8ba1\u7b97\u6210\u672c\u3002\u5728<t>\u7f16\u7801</t>\u8fc7\u7a0b\u4e2d\u8f83\u65e9\u5730\u51cf\u5c11<t>\u8f93\u5165</t>\u957f\u5ea6\uff0c\u53ef\u4ee5\u663e\u8457\u964d\u4f4e\u8ba1\u7b97\u6210\u672c\u3002\u5bf9\u4e8e\u91d1\u5b57\u5854<t>\u6a21\u578b</t>\uff0c\u6211\u4eec\u5c06<t>\u8868\u793a</t>\u7684\u5927\u5c0f\u7f29\u5c0f\u5230\u6bcf\u4e2a\u9009\u5b9a\u5c42\u7684\u8f93\u51fa\u5904\uff0c\u4ece\u800c\u5b9e\u73b0<t>\u8ba1\u7b97</t>\u6210\u672c\u7684\u6307\u6570\u7ea7\u964d\u4f4e\uff0c\u56e0\u4e3a<t>\u7f16\u7801</t>\u8fc7\u7a0b\u4e0d\u65ad\u8fdb\u884c\u3002\u6b63\u5982\u4f60\u6240\u89c1\uff0c\u603b<t>\u8ba1\u7b97</t>\u6210\u672c\u5728\u6b64\u5904\u7684\u5b8c\u6574<t>\u7f16\u7801\u5668</t>\u4e2d\u4e0d\u5230\u5168\u5c3a\u5bf8\u7b2c\u4e00\u5c42\u7684\u4e24\u500d\u3002\u5f53\u8f83\u65e9\u5f15\u5165\u6c60\u5316\u64cd\u4f5c\u65f6\uff0c\u6240\u6709\u7d2b\u8272\u65b9\u5757\u7684\u603b\u548c\u8fdc\u4f4e\u4e8e\u4e00\u4e2a\u5e38\u6570\uff0c\u4e14\u4e0d\u4f9d\u8d56\u4e8e\u5c42\u6570L\uff0c\u800c\u662f\u4f9d\u8d56\u4e8e\u5e38\u6570c\uff0c\u800cc\u53ef\u4ee5\u53d7\u5230\u7f51\u7edc\u4e2d\u6c60\u5316\u5c42\u4f4d\u7f6e\u7684\u5f71\u54cd\u3002\u6211\u4eec\u7684\u6539\u8fdb\u5728\u516b\u5343\u4e2a<t>\u4ee4\u724c</t>\u957f\u5ea6\u7684<t>\u8f93\u5165</t>\u4e0a\u8fdb\u884c\u4e86\u57fa\u51c6\u6d4b\u8bd5\uff0c\u56fe\u4e2d\u663e\u793a\uff0c\u5f53\u542f\u7528\u6c60\u5316\u64cd\u4f5c\u65f6\uff0c\u7f51\u7edc\u6df1\u5ea6\u7684\u6700\u4f73\u53ef\u6269\u5c55\u6027\u5f97\u4ee5\u5b9e\u73b0\u3002\u5728\u8fd9\u91cc\u53ef\u4ee5\u6ce8\u610f\u5230\uff0c<t>\u8bad\u7ec3</t>\u91d1\u5b57\u5854\u5c42\uff08\u5171\u4e8c\u5341\u56db\u5c42\uff09\u53ef\u80fd\u6bd4<t>\u8bad\u7ec3</t>\u4e00\u4e2a\u4e24\u5c42\u7684\u666e\u901a<t>\u8f6c\u6362\u5668</t>\u66f4\u4fbf\u5b9c\uff0c\u5c24\u5176\u662f\u5728\u5982\u6b64\u957f\u7684<t>\u8f93\u5165</t>\u4e0a\u3002\u66f4\u4e0d\u7528\u8bf4\uff0c\u666e\u901a<t>\u8f6c\u6362\u5668</t>\u5728\u5982\u6b64\u957f\u7684<t>\u8f93\u5165</t>\u4e0a\u5f88\u5bb9\u6613\u8d85\u51fa\u5185\u5b58\u9650\u5236\u3002<t>\u5b9a\u6027</t>\u6bd4\u8f83\u6211\u4eec\u8bad\u7ec3\u7684\u91d1\u5b57\u5854\u6a21\u578b\u4e0e\u5176\u4ed6<t>\u57fa\u7ebf</t>\u6a21\u578b\u5728\u957f<t>\u6587\u6863</t>\u6458\u8981<t>\u4efb\u52a1</t>\u4e0a\u7684\u8868\u73b0\uff0c\u7ed9\u51fa\u4e86\u6765\u81eaarchive\u6216PubMed\u7684<t>\u6