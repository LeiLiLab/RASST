u4e9b<t>\u53e5\u5b50</t>\u6216<t>\u6587\u6863</t>\u4f20\u9012\u7ed9\u4e00\u4e2a<t>\u5f62\u6001\u5316\u5206\u6790\u5668</t>\u3002\u8be5\u5206\u6790\u5668\u968f\u540e<t>\u751f\u6210</t><t>\u5355\u8bcd</t>\u4e2d\u5305\u542b\u7684<t>\u8bed\u7d20</t>\u3002\u8fd9\u4e9b<t>\u8bed\u7d20</t>\u901a\u5e38\u7531\u4e00\u4e2a\u8bcd\u5e72\u548c\u96f6\u4e2a\u6216\u591a\u4e2a\u8bcd\u7f00\u7ec4\u6210\u3002\u8bcd\u7f00\u53ef\u4ee5\u8868\u793a\u65f6\u6001\u3001\u4f53\u3001\u4e3b\u8bed\u6216<t>\u52a8\u8bcd</t>\u7684\u5bbe\u8bed\uff0c\u4ee5\u53ca\u66f4\u591a\u4e0e\u73ed\u56fe\u8bed\u540d\u8bcd\u7c7b\u76f8\u5173\u7684\u5185\u5bb9\uff0c\u7528\u4e8e\u8868\u793a\u4e3b\u8bed\u548c\u5bbe\u8bed\u3002<t>\u5f62\u6001\u5316</t>\u5206\u6790\u5668\u8fd8\u4f1a\u4e3a\u6bcf\u4e2a<t>\u5355\u8bcd</t>\u751f\u6210\u4e00\u4e2a\u8bcd\u6027\u6807\u7b7e\u3002\u7ecf\u8fc7\u8fd9\u4e00\u6b65\u9aa4\u540e\uff0c\u6211\u4eec\u4e3a\u8fd9\u4e9b\u8bcd\u6027\u6807\u7b7e\u751f\u6210<t>\u5d4c\u5165</t>\u3002\u5bf9\u4e8e\u8bcd\u7f00\u7684<t>\u5d4c\u5165</t>\uff0c\u4ee5\u53ca\u8bcd\u5e72\u7684<t>\u5d4c\u5165</t>\u3002\u8fd9\u4e9b\u662f<t>\u5f62\u6001\u5b66</t>\u6807\u7b7e\u3002\u8fd9\u4e9b\u662f\u5f62\u6001\u5b66\u5c42\u9762\u7684<t>\u5d4c\u5165</t>\u3002\u7136\u540e\u6211\u4eec\u5c06\u8fd9\u4e9b<t>\u5d4c\u5165</t>\u901a\u8fc7\u4e00\u4e2a<t>\u5f62\u6001\u5b66</t><t>\u7f16\u7801\u5668</t>\u4f20\u9012\uff0c\u8be5\u7f16\u7801\u5668\u662f\u4e00\u4e2a\u5c0f\u578b<t>\u8f6c\u6362\u5668</t>\u7f16\u7801\u5668\uff0c\u5b83\u72ec\u7acb\u5e94\u7528\u4e8e\u6bcf\u4e2a<t>\u5355\u8bcd</t>\u3002<t>\u5f62\u6001\u5b66</t>\u7f16\u7801\u5668\u7684\u8f93\u51fa\u662f\u5305\u542b<t>\u5f62\u6001\u5316</t>\u4fe1\u606f\u7684<t>\u5411\u91cf</t>\u3002\u5728<t>\u5355\u8bcd</t>\u5c42\u9762\u8fdb\u884c<t>\u60c5\u5883\u5316</t>\u3002\u73b0\u5728\u6211\u4eec\u8fdb\u884c\u7ec4\u5408\u3002<t>\u5f62\u6001\u5316</t>\u5d4c\u5165<t>\u5bf9\u5e94</t>\u4e8e\u8bcd\u6027\u548c\u8bcd\u5e72\uff0c\u88ab\u62fc\u63a5\u5728\u4e00\u8d77\u3002\u6211\u4eec\u8fdb\u4e00\u6b65\u5c06\u5b83\u4eec\u4e0e\u53e6\u4e00\u4e2a\u8bcd\u5e72<t>\u5d4c\u5165</t>\u5728<t>\u53e5\u5b50</t>\u5c42\u9762\u8fdb\u884c\u62fc\u63a5\uff0c\u7136\u540e\u6211\u4eec\u5f62\u6210\u4e3b<t>\u53e5\u5b50</t>\u6216\u6587\u6863<t>\u7f16\u7801\u5668</t>\u7684\u8f93\u5165\u3002\u6700\u7ec8\u8f93\u51fa\u662f<t>\u60c5\u5883\u5316</t>\u7684<t>\u5d4c\u5165</t>\uff0c\u53ef\u7528\u4e8e<t>\u4e0b\u6e38</t>\u7684<t>\u81ea\u7136\u8bed\u8a00\u5904\u7406</t>\u4efb\u52a1\u3002\u5bf9\u4e8e<t>\u5f62\u6001\u5316\u5206\u6790\u5668</t>\uff0c\u6211\u4eec\u4f7f\u7528\u6709\u9650\u72b6\u6001\u4e24\u5c42\u5f62\u6001\u5b66\u539f\u7406\uff0c\u5e76\u91c7\u7528\u9488\u5bf9\u57fa\u5c3c\u4e9a\u9c81\u65fa\u8fbe\u8bed\u5b9a\u5236\u7684\u5b9e\u73b0\u65b9\u5f0f\u3002\u6211\u4eec\u6709\u6548\u5730\u5efa\u6a21\u4e86\u6240\u6709\u57fa\u5c3c\u4e9a\u9c81\u65fa\u8fbe\u8bed<t>\u5355\u8bcd</t>\u7684\u5f62\u6001\uff0c\u5305\u62ec\u52a8\u8bcd\u3001<t>\u540d\u8bcd</t>\u3001\u6307\u793a\u4ee3\u8bcd\u548c\u7269\u4e3b\u4ee3\u8bcd\u3001\u6570\u8bcd\u53ca\u5176\u4ed6\u8bcd\u7c7b\u3002\u6211\u4eec\u4f7f\u7528<t>\u65e0\u76d1\u7763</t>\u7684\u8bcd\u6027<t>\u6807\u8bb0</t><t>\u7b97\u6cd5</t>\uff0c\u9996\u5148\u91c7\u7528\u4e00\u4e2a\u56e0\u5b50\u5206\u89e3\u6a21\u578b\u6765\u8003\u8651<t>\u5f62\u6001\u5b66</t>\u6982\u7387\uff0c\u57fa\u672c\u4e0a\u5c31\u662f<t>\u5f62\u6001\u5316\u5206\u6790\u5668</t>\u6240\u5206\u914d\u7684\u6982\u7387\u3002\u6211\u4eec\u8fd8\u8003\u8651\u5230\u8bcd\u6027<t>\u6807\u8bb0</t>\u7684\u5148\u9a8c\u4fe1\u606f\u4ee5\u53ca<t>\u53e5\u6cd5</t>\u4e00\u81f4\u6027\u7684<t>\u8f93\u5165</t><t>\u5355\u8bcd</t>\u4e2d\u6240\u4f53\u73b0\u7684\u5185\u5bb9\u3002\u8bcd\u6027<t>\u6807\u8bb0\u5668</t>\u4f7f\u7528\u7684\u662f<t>\u53cc\u5411</t><t>\u63a8\u7406</t>\uff0c\u8fd9\u6bd4\u66f4\u5e38\u7528\u7684\u7ef4\u7279\u6bd4<t>\u7b97\u6cd5</t><t>\u89e3\u7801</t>\u6548\u679c\u66f4\u597d\u3002\u8fd9\u91cc\u5bf9<t>\u4f4d\u7f6e\u7f16\u7801</t>\u4f5c\u51e0\u70b9\u8bf4\u660e\u3002\u9996\u5148\uff0c<t>\u5f62\u6001\u5b66</t>\u7f16\u7801\u5668\u4e0d\u4f7f\u7528\u4efb\u4f55<t>\u4f4d\u7f6e\u7f16\u7801</t>\uff0c\u56e0\u4e3a\u6bcf\u4e2a<t>\u8bed\u7d20</t>\u5728<t>\u5f62\u6001\u5b66</t>\u6a21\u578b\u4e2d\u5360\u636e\u4e00\u4e2a\u786e\u5b9a\u7684\u4f4d\u7f6e\uff0c\u56e0\u6b64<t>\u4f4d\u7f6e\u4fe1\u606f</t>\u5728<t>\u8bed\u7d20</t>\u8f93\u5165\u65f6\u5df2\u9690\u542b\u5b58\u5728\u3002\u5176\u6b21\uff0c<t>\u53e5\u5b50</t><t>\u7f16\u7801\u5668</t>\u4f7f\u7528\u6240\u8c13\u7684\u65e0\u504f\u7f6e\u76f8\u5bf9<t>\u4f4d\u7f6e\u7f16\u7801</t>\uff0c\u8fd9\u79cd\u7f16\u7801\u6700\u8fd1\u5728ICLR\u4f1a\u8bae\u4e0a\u53d1\u8868\u3002\u8fd9\u79cd<t>\u4f4d\u7f6e\u7f16\u7801</t>\u672c\u8d28\u4e0a\u5c06\u4f4d\u7f6e<t>\u76f8\u5173\u6027</t>\u4e0e<t>\u4ee4\u724c</t>\u95f4<t>\u6ce8\u610f\u529b</t><t>\u8ba1\u7b97</t>\u89e3\u8026\u3002\u4e0e<t>BERT</t>\u7c7b\u4f3c\uff0c\u6211\u4eec\u4f7f\u7528\u63a9\u7801<t>\u8bed\u8a00</t><t>\u6a21\u578b</t><t>\u9884\u8bad\u7ec3</t>\u76ee\u6807\u3002\u672c\u8d28\u4e0a\uff0c\u6211\u4eec\u9700\u8981\u9884\u6d4b\u8bcd\u5e72\u548c\u8bcd\u7f00\uff0c\u8fd9\u4e9b\u662f\u4e0e<t>\u5355\u8bcd</t>\u76f8\u5173\u8054\u7684\u3002\u5728<t>\u9884\u8bad\u7ec3</t>\u8fc7\u7a0b\u4e2d\uff0c\u6240\u6709<t>\u5355\u8bcd</t>\u4e2d\u670915%\u88ab\u8003\u8651\u8fdb\u884c<t>\u9884\u6d4b</t>\uff0c\u5176\u4e2d80%\u88ab\u63a9\u7801\uff0c10%\u88ab\u66ff\u6362\u4e3a\u968f\u673a<t>\u5355\u8bcd</t>\uff0c10%\u4fdd\u6301\u4e0d\u53d8\u3002\u5bf9\u4e8e\u8bcd\u7f00<t>\u9884\u6d4b</t>\uff0c\u6211\u4eec\u9762\u4e34\u4e00\u4e2a\u591a\u6807\u7b7e\u5206\u7c7b<t>\u95ee\u9898</t>\u3002\u4e3a\u6b64\uff0c\u6211\u4eec\u5c06\u8bcd\u7f00\u5206\u7ec4\u4e3a\u56fa\u5b9a\u6570\u91cf\u7684\u7c7b\u522b\uff0c\u9884\u6d4b\u8be5\u7c7b\u522b\uff0c\u6216\u9009\u62e9\u9884\u6d4b\u8bcd\u7f00\u7684\u6982\u7387<t>\u5411\u91cf</t>\u3002\u6211\u4eec\u8bc4\u4f30\u4e86\u8fd9\u4e24\u79cd<t>\u65b9\u6cd5</t>\u3002\u6211\u4eec\u5728\u7ea62.5\u5409\u5b57\u8282\u7684\u57fa\u52aa\u9c81\u5b89\u8fbe<t>\u6587\u672c</t>\u4e0a<t>\u9884\u8bad\u7ec3</t><t>KinyaBERT</t>\uff0c\u5e76\u4e0e\u4e09\u79cd\u57fa\u7ebf<t>\u6a21\u578b</t><t>\u76f8\u6bd4</t>\u3002\u5176\u4e2d\u4e00\u79cd\u662f\u591a\u8bed\u8a00<t>\u6a21\u578b</t>\uff0c\u79f0\u4e3aXLM-R\uff0c\u8be5\u6a21\u578b\u5728\u5927\u91cf<t>\u6587\u672c</t><t>\u8bed\u6599\u5e93</t>\u4e0a\u8bad\u7ec3\u800c\u6210\uff0c\u8be5\u8bed\u6599\u5e93\u7531\u591a\u79cd<t>\u8bed\u8a00</t>\u6784\u6210\u3002\u53e6\u5916\u4e24\u79cd\u57fa\u7ebf<t>\u6a21\u578b</t>\u5219\u5728\u76f8\u540c\u7684\u57fa\u52aa\u9c81\u5b89\u8fbe<t>\u6587\u672c</t>\u4e0a\u8fdb\u884c<t>\u9884\u8bad\u7ec3</t>\uff0c\u5206\u522b\u4f7f\u7528\u5b57\u8282\u5bf9<t>\u7f16\u7801</t><t>\u7b97\u6cd5</t>\uff0c\u6216\u4f7f\u7528<t>\u5f62\u6001\u5206\u6790</t>\uff0c\u4f46\u4e0d\u4f7f\u7528<t>\u8f6c\u6362\u5668\u7f16\u7801\u5668</t>\u67b6\u6784\u3002\u6240\u6709<t>\u6a21\u578b</t>\u5747\u914d\u7f6e\u4e3a\u57fa\u7840\u67b6\u6784\uff0c\u53c2\u6570\u91cf\u7ea6\u4e3a\u4e00\u767e\u5230\u4e00\u4ebf\u4e00\u5343\u4e07\u3002<t>KinyaBERT</t>\u4f7f\u7528\u7684\u53c2\u6570\u6700\u5c11\u3002\u6240\u6709\u6a21\u578b\uff0c\u9664\u4e86\u591a<t>\u8bed\u8a00</t>\u6a21\u578b\u5916\uff0c\u5747\u7ecf\u8fc7\u4e86\u4e09\u4e07\u4e24\u5343\u6b21<t>\u68af\u5ea6</t>\u66f4\u65b0\u7684\u9884\u8bad\u7ec3\uff0c<t>\u6279\u91cf</t>\u5927\u5c0f\u4e3a2560\u4e2a<t>\u5e8f\u5217</t>\u3002\u6bcf\u6279\u6b21\u5305\u542b2560\u4e2a<t>\u5e8f\u5217</t>\u3002\u6211\u4eec\u5728\u4e09\u7ec4<t>\u4efb\u52a1</t>\u4e0a\u8bc4\u4f30\u4e86<t>\u9884\u8bad\u7ec3</t>\u6a21\u578b\uff0c\u5176\u4e2d\u4e00\u7ec4\u662fGLUE\u57fa\u51c6\uff0c\u8be5\u57fa\u51c6\u5e38\u7528\u4e8e\u8bc4\u4f30<t>\u9884\u8bad\u7ec3\u8bed\u8a00\u6a21\u578b</t>\u7684\u6709\u6548\u6027\u3002\u6211\u4eec\u4ece\u57fa\u51c6<t>\u6570\u636e</t>\u4e2d\u83b7\u53d6\u4e86\u6211\u4eec\u7684\u6570\u636e\uff0c\u901a\u8fc7\u5c06\u539f\u59cb\u57fa\u51c6<t>\u6570\u636e</t>\u7ffb\u8bd1\u6210\u5362\u65fa\u8fbe\u8bed\uff0c\u5e76\u4f7f\u7528\u8c37\u6b4c\u7ffb\u8bd1\u3002\u7b2c\u4e8c\u4e2a<t>\u4efb\u52a1</t>\u662f\u5362\u65fa\u8fbe\u8bed\u547d\u540d\u5b9e\u4f53\u8bc6\u522b\u57fa\u51c6\uff0c\u8fd9\u662f\u4e00\u4e2a\u9ad8\u8d28\u91cf\u7684<t>\u6570\u636e</t>\u96c6\uff0c\u7531\u53d7\u8fc7\u8bad\u7ec3\u7684\u6bcd\u8bed\u8005\u6807\u6ce8\u800c\u6210\u3002\u7b2c\u4e09\u4e2a\u662f\u65b0\u95fb\u5206\u7c7b<t>\u4efb\u52a1</t>\uff0c\u6211\u4eec\u4ece\u51e0\u4e2a\u7f51\u7ad9\u83b7\u53d6<t>\u65b0\u95fb</t>\u6587\u7ae0\uff0c\u5e76\u6536\u96c6\u5b83\u4eec\u7684\u4f5c\u8005\u5206\u914d\u7684\u5206\u7c7b\u6807\u7b7e\uff0c\u7136\u540e\u672c\u8d28\u4e0a\u662f\u5c1d\u8bd5\u9884\u6d4b\u8fd9\u4e9b\u5206\u7c7b\u3002\u73b0\u5728\u6211\u4eec\u8fdb\u5165<t>\u7ed3\u679c</t>\u90e8\u5206\u3002\u5bf9\u4e8eGLUE\u57fa\u51c6\uff0c\u6211\u4eec\u53d1\u73b0<t>KinyaBERT</t>\u59cb\u7ec8\u4f18\u4e8e<t>\u57fa\u7ebf</t><t>\u6a21\u578b</t>\uff0c\u8fd9\u91cc\u6211\u4eec\u5c55\u793a\u4e86<t>\u5fae\u8c03</t>\u5341\u6b21\u7684\u5e73\u5747\u6027\u80fd\u3002\u6211\u4eec\u8fd8\u5bf9\u8c37\u6b4c<t>\u7ffb\u8bd1</t>\u751f\u6210\u7684<t>\u7ffb\u8bd1</t>\u8fdb\u884c\u4e86<t>\u7528\u6237</t><t>\u8bc4\u4f30</t>\u3002\u57fa\u672c\u4e0a\uff0c<t>\u7528\u6237</t>\u5bf9\u5927\u7ea6\u516d\u5343\u4e2a\u793a\u4f8b\u8fdb\u884c\u4e86\u8bc4\u5206\u3002\u8bc4\u5206\u8303\u56f4\u4ece\u4e00\u5230\u56db\uff0c\u4ee5\u8bc4\u4f30<t>\u7ffb\u8bd1</t>\u7684<t>\u8d28\u91cf</t>\u3002\u7ed3\u679c\u663e\u793a\uff0c\u8bb8\u591a\u7ffb\u8bd1\u5b58\u5728\u566a\u97f3\u3002\u4f46\u6240\u6709<t>\u6a21\u578b</t>\u90fd\u5fc5\u987b\u5e94\u5bf9\u76f8\u540c\u7684\u7ffb\u8bd1\u566a\u97f3\uff0c\u800c<t>\u6a21\u578b</t>\u4e4b\u95f4\u7684\u76f8\u5bf9\u6027\u80fd\u4ecd\u503c\u5f97\u6ce8\u610f\u3002\u5bf9\u4e8e<t>\u547d\u540d\u5b9e\u4f53\u8bc6\u522b</t>\u4efb\u52a1\uff0c\u6211\u4eec\u53d1\u73b0<t>KinyaBERT</t>\u8868\u73b0\u6700\u4f73\u3002\u540e\u7f00\u5206\u5e03<t>\u6a21\u578b</t>\u8868\u73b0\u6700\u4f73\u3002\u8fd9\u4e9b\u7ed3\u679c\u4e5f\u662f<t>\u5fae\u8c03</t>\u5341\u6b21\u7684\u5e73\u5747\u503c\u3002\u5bf9\u4e8e\u65b0\u95fb\u5206\u7c7b<t>\u4efb\u52a1</t>\uff0c\u6211\u4eec\u53d1\u73b0\u7ed3\u679c\u53c2\u5d