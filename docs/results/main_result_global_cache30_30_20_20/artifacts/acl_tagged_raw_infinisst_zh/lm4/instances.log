u7ed9\u5f62\u6001\u5206\u6790\u5668\uff0c\u8be5\u5206\u6790\u5668\u968f\u540e\u751f\u6210\u6bcf\u4e2a\u5355\u8bcd\u4e2d\u7684\u5f62\u6001\u7d20\u3002\u8fd9\u4e9b\u5f62\u6001\u7d20\u901a\u5e38\u7531\u4e00\u4e2a\u8bcd\u5e72\u548c\u96f6\u4e2a\u6216\u591a\u4e2a\u8bcd\u7f00\u7ec4\u6210\u3002\u8bcd\u7f00\u53ef\u80fd\u8868\u793a\u65f6\u6001\u3001\u4f53\u3001\u4e3b\u8bed\u6216\u52a8\u8bcd\u7684\u5bbe\u8bed\uff0c\u66f4\u5e38\u4e0e\u73ed\u56fe\u8bed\u540d\u8bcd\u7c7b\u522b\u76f8\u5173\uff0c\u7528\u4e8e\u8868\u793a\u4e3b\u8bed\u548c\u5bbe\u8bed\u3002\u5f62\u6001\u5206\u6790\u5668\u8fd8\u4e3a\u6bcf\u4e2a\u5355\u8bcd\u751f\u6210\u8bcd\u6027\u6807\u6ce8\u3002\u5b8c\u6210\u8fd9\u4e00\u6b65\u540e\uff0c\u6211\u4eec\u4e3a\u8bcd\u6027\u6807\u6ce8\u751f\u6210\u5d4c\u5165\u8868\u793a\u3002\u8bcd\u7f00\u7684\u5d4c\u5165\u8868\u793a\u3002\u8bcd\u5e72\u7684\u5d4c\u5165\u8868\u793a\u3002\u8fd9\u4e9b\u662f\u5f62\u6001\u5b66\u5c42\u9762\u7684\u5d4c\u5165\u8868\u793a\uff0c\u5373\u5f62\u6001\u5b66\u5d4c\u5165\u3002\u7136\u540e\u5c06\u8fd9\u4e9b\u5d4c\u5165\u4f20\u9012\u7ed9\u4e00\u4e2a\u5f62\u6001\u5b66\u7f16\u7801\u5668\uff0c\u5b83\u662f\u4e00\u4e2a\u5c0f\u578b\u7684Transformer\u7f16\u7801\u5668\uff0c\u5bf9\u6bcf\u4e2a\u5355\u8bcd\u72ec\u7acb\u8fdb\u884c\u5904\u7406\u3002\u8f93\u51fa\u7684\u662f\u7ed3\u5408\u4e86\u5f62\u6001\u5b66\u4fe1\u606f\u7684\u4e0a\u4e0b\u6587\u5411\u91cf\u3002\u73b0\u5728\u6211\u4eec\u8fdb\u884c\u7ec4\u5408\uff0c\u5176\u4e2d\u5f62\u6001\u5b66\u5d4c\u5165\uff08\u5bf9\u5e94\u8bcd\u6027\u4e0e\u8bcd\u5e72\uff09\u88ab\u62fc\u63a5\u5728\u4e00\u8d77\u3002\u6211\u4eec\u8fdb\u4e00\u6b65\u5c06\u5b83\u4eec\u4e0e\u53e5\u5b50\u5c42\u9762\u7684\u53e6\u4e00\u4e2a\u8bcd\u5e72\u5d4c\u5165\u8868\u793a\u62fc\u63a5\u3002\u7136\u540e\uff0c\u6211\u4eec\u5c06\u5176\u4f5c\u4e3a\u4e3b\u53e5\u5b50\u6216\u6587\u6863\u7f16\u7801\u5668\u7684\u8f93\u5165\u3002\u6700\u7ec8\u8f93\u51fa\u7684\u662f\u4e0a\u4e0b\u6587\u5d4c\u5165\u8868\u793a\uff0c\u53ef\u7528\u4e8e\u4e0b\u6e38\u4efb\u52a1\u3002\u5bf9\u4e8e\u5f62\u6001\u5b66\u5206\u6790\u5668\uff0c\u6211\u4eec\u91c7\u7528\u6709\u9650\u72b6\u6001\u4e24\u5c42\u5f62\u6001\u5b66\u5206\u6790\u539f\u7406\uff0c\u5e76\u7ed3\u5408\u81ea\u5b9a\u4e49\u5b9e\u73b0\uff0c\u8be5\u5b9e\u73b0\u9488\u5bf9\u57fa\u5c3c\u4e9a\u5362\u65fa\u8fbe\u8bed\u8fdb\u884c\u4e86\u8c03\u6574\u3002\u6211\u4eec\u6709\u6548\u5730\u5efa\u6a21\u4e86\u6240\u6709\u57fa\u5c3c\u4e9a\u5362\u65fa\u8fbe\u8bed\u5355\u8bcd\u7684\u5f62\u6001\u7ed3\u6784\uff0c\u5305\u62ec\u52a8\u8bcd\u3001\u540d\u8bcd\u3001\u6307\u793a\u4ee3\u8bcd\u548c\u6240\u6709\u683c\u4ee3\u8bcd\u3002\u6211\u4eec\u4f7f\u7528\u65e0\u76d1\u7763\u8bcd\u6027\u6807\u6ce8\u7b97\u6cd5\u3002\u9996\u5148\u4f7f\u7528\u56e0\u5b50\u5206\u89e3\u6a21\u578b\u6765\u8003\u8651\u5f62\u6001\u5b66\u6982\u7387\uff0c\u5373\u5f62\u6001\u5b66\u5206\u6790\u5668\u5206\u914d\u7684\u6982\u7387\u3002\u6211\u4eec\u8fd8\u8003\u8651\u4e86\u8bcd\u6027\u6807\u7b7e\u7684\u4f18\u5148\u7ea7\u4ee5\u53ca\u8f93\u5165\u8bcd\u4e2d\u5b58\u5728\u7684\u53e5\u6cd5\u4e00\u81f4\u5173\u7cfb\u3002\u8bcd\u6027\u6807\u6ce8\u5668\u91c7\u7528\u53cc\u5411\u63a8\u7406\uff0c\u4f18\u4e8e\u66f4\u5e38\u7528\u7684\u7ef4\u7279\u6bd4\u7b97\u6cd5\u3002\u8fd9\u91cc\u5bf9\u4f4d\u7f6e\u7f16\u7801\u6709\u51e0\u70b9\u8bf4\u660e\u3002\u5f62\u6001\u7f16\u7801\u5668\u4e0d\u4f7f\u7528\u4efb\u4f55\u4f4d\u7f6e\u7f16\u7801\uff0c\u56e0\u4e3a\u6bcf\u4e2a\u8bcd\u7d20\u5728\u5f62\u6001\u6a21\u578b\u4e2d\u5360\u636e\u4e00\u4e2a\u5df2\u77e5\u7684\u4f4d\u7f6e\uff0c\u56e0\u6b64\u4f4d\u7f6e\u4fe1\u606f\u5df2\u5305\u542b\u5728\u8bcd\u7d20\u4e2d\u3002\u5176\u6b21\uff0c\u53e5\u5b50\u7f16\u7801\u5668\u4f7f\u7528\u6240\u8c13\u7684\u201c\u672a\u7ed1\u5b9a\u201d\u76f8\u5bf9\u4f4d\u7f6e\u5d4c\u5165\uff0c\u8be5\u65b9\u6cd5\u6700\u8fd1\u5df2\u5728ICLR\u4f1a\u8bae\u4e0a\u53d1\u8868\u3002\u8fd9\u79cd\u4f4d\u7f6e\u5d4c\u5165\u672c\u8d28\u4e0a\u5c06\u4f4d\u7f6e\u76f8\u5173\u6027\u4e0e\u8bcd\u4e0e\u8bcd\u4e4b\u95f4\u7684\u6ce8\u610f\u529b\u8ba1\u7b97\u89e3\u8026\u3002\u4e0eBERT\u7c7b\u4f3c\uff0c\u6211\u4eec\u4f7f\u7528\u63a9\u7801\u8bed\u8a00\u6a21\u578b\u9884\u8bad\u7ec3\u76ee\u6807\u3002\u672c\u8d28\u4e0a\uff0c\u6211\u4eec\u9700\u8981\u9884\u6d4b\u5355\u8bcd\u7684\u8bcd\u5e72\u53ca\u5176\u76f8\u5173\u7684\u8bcd\u7f00\u3002\u5728\u9884\u8bad\u7ec3\u671f\u95f4\uff0c\u6240\u6709\u5355\u8bcd\u4e2d\u670915%\u88ab\u9009\u4e2d\u8fdb\u884c\u9884\u6d4b\uff0c\u5176\u4e2d80%\u88ab\u63a9\u7801\uff0c10%\u88ab\u968f\u673a\u5355\u8bcd\u66ff\u6362\uff0c10%\u4fdd\u6301\u4e0d\u53d8\u3002\u5bf9\u4e8e\u8bcd\u7f00\u9884\u6d4b\uff0c\u6211\u4eec\u9762\u4e34\u4e00\u4e2a\u591a\u6807\u7b7e\u5206\u7c7b\u95ee\u9898\u3002\u4e3a\u6b64\uff0c\u6211\u4eec\u5c06\u8bcd\u7f00\u5206\u7ec4\u4e3a\u56fa\u5b9a\u6570\u91cf\u7684\u96c6\u5408\uff0c\u5e76\u5c06\u96c6\u5408\u4f5c\u4e3a\u7c7b\u522b\u6807\u7b7e\u8fdb\u884c\u9884\u6d4b\u3002\u53e6\u4e00\u79cd\u9009\u62e9\u662f\u9884\u6d4b\u8bcd\u7f00\u7684\u6982\u7387\u5411\u91cf\u3002\u6211\u4eec\u8bc4\u4f30\u4e86\u8fd9\u4e24\u79cd\u65b9\u6cd5\u5728\u5b9e\u9a8c\u4e2d\u7684\u8868\u73b0\u3002\u6211\u4eec\u5728\u7ea62.5GB\u7684\u5362\u65fa\u8fbe\u8bed\u6587\u672c\u4e0a\u5bf9KENYA-BERT\u8fdb\u884c\u4e86\u9884\u8bad\u7ec3\uff0c\u5e76\u5c06\u5176\u4e0e\u4e09\u79cd\u57fa\u7ebf\u6a21\u578b\u8fdb\u884c\u4e86\u6bd4\u8f83\u3002\u5176\u4e2d\u4e00\u79cd\u662f\u591a\u8bed\u8a00\u6a21\u578b\uff0c\u79f0\u4e3aXLM-R\uff0c\u5b83\u5728\u5927\u578b\u6587\u672c\u8bed\u6599\u5e93\u4e0a\u8bad\u7ec3\uff0c\u8be5\u8bed\u6599\u5e93\u7531\u591a\u79cd\u8bed\u8a00\u7ec4\u6210\u3002\u53e6\u5916\u4e24\u79cd\u57fa\u7ebf\u6a21\u578b\u662f\u5728\u76f8\u540c\u7684\u5362\u65fa\u8fbe\u8bed\u6587\u672c\u4e0a\u8fdb\u884c\u9884\u8bad\u7ec3\u7684\u6a21\u578b\uff0c\u5206\u522b\u91c7\u7528\u5b57\u8282\u5bf9\u7f16\u7801\u7b97\u6cd5\u6216\u5f62\u6001\u5206\u6790\uff0c\u4f46\u672a\u4f7f\u7528\u4e24\u9636\u6bb5Transformer\u7f16\u7801\u5668\u67b6\u6784\u3002\u6240\u6709\u6a21\u578b\u5747\u914d\u7f6e\u4e3aBASE\u67b6\u6784\uff0c\u53c2\u6570\u91cf\u7ea6\u4e3a\u4e00\u4ebf\u5230\u4e00\u4ebf\u4e00\u5343\u4e07\u4e2a\u53c2\u6570\u3002KENYA-BERT\u4f7f\u7528\u7684\u53c2\u6570\u6700\u5c11\u3002\u6240\u6709\u6a21\u578b\uff08\u9664\u591a\u8bed\u8a00\u6a21\u578b\u5916\uff09\u5747\u57282000\u4e2a\u68af\u5ea6\u66f4\u65b0\u6b65\u9aa4\u4e0a\u8fdb\u884c\u9884\u8bad\u7ec3\uff0c\u6279\u6b21\u5927\u5c0f\u4e3a2000\u3002\u6bcf\u4e2a\u6279\u6b21\u5305\u542b2560\u4e2a\u5e8f\u5217\u3002\u6211\u4eec\u5728\u4e09\u7ec4\u4efb\u52a1\u4e0a\u8bc4\u4f30\u4e86\u9884\u8bad\u7ec3\u6a21\u578b\u3002\u5176\u4e2d\u4e00\u7ec4\u662fGLUE\u57fa\u51c6\u6d4b\u8bd5\uff0c\u8be5\u57fa\u51c6\u6d4b\u8bd5\u5e38\u7528\u4e8e\u8bc4\u4f30\u9884\u8bad\u7ec3\u8bed\u8a00\u6a21\u578b\u7684\u6709\u6548\u6027\u3002\u6211\u4eec\u83b7\u53d6\u4e86GLUE\u57fa\u51c6\u6d4b\u8bd5\u6570\u636e\uff0c\u65b9\u6cd5\u662f\u5c06\u539f\u59cb\u57fa\u51c6\u6d4b\u8bd5\u6570\u636e\u7ffb\u8bd1\u6210\u5362\u65fa\u8fbe\u8bed\uff0c\u4f7f\u7528\u7684\u662f\u8c37\u6b4c\u7ffb\u8bd1\u3002\u7b2c\u4e8c\u4e2a\u4efb\u52a1\u662f\u5362\u65fa\u8fbe\u8bed\u547d\u540d\u5b9e\u4f53\u8bc6\u522b\u57fa\u51c6\u6d4b\u8bd5\uff0c\u8fd9\u662f\u4e00\u4e2a\u9ad8\u8d28\u91cf\u7684\u6570\u636e\u96c6\uff0c\u7531\u53d7\u8fc7\u57f9\u8bad\u7684\u6bcd\u8bed\u8005\u6807\u6ce8\u3002\u7b2c\u4e09\u4e2a\u4efb\u52a1\u662f\u65b0\u95fb\u5206\u7c7b\u4efb\u52a1\u3002\u6211\u4eec\u4ece\u591a\u4e2a\u7f51\u7ad9\u83b7\u53d6\u65b0\u95fb\u6587\u7ae0\uff0c\u5e76\u6536\u96c6\u4f5c\u8005\u5206\u914d\u7684\u5206\u7c7b\u6807\u7b7e\u3002\u7136\u540e\uff0c\u6211\u4eec\u57fa\u672c\u4e0a\u5c1d\u8bd5\u9884\u6d4b\u76f8\u540c\u7684\u7c7b\u522b\u3002\u73b0\u5728\u6211\u4eec\u6765\u770b\u7ed3\u679c\u3002\u5728GLUE\u57fa\u51c6\u6d4b\u8bd5\u4e2d\uff0c\u6211\u4eec\u53d1\u73b0Kinyabert\u59cb\u7ec8\u4f18\u4e8e\u57fa\u7ebf\u6a21\u578b\u3002\u8fd9\u91cc\u6211\u4eec\u5c55\u793a\u7684\u662f\u5e73\u5747\u6027\u80fd\uff0c\u57fa\u4e8e\u5341\u6b21\u5fae\u8c03\u8fd0\u884c\u7684\u7ed3\u679c\u3002\u6211\u4eec\u8fd8\u5bf9\u8c37\u6b4c\u7ffb\u8bd1\u751f\u6210\u7684\u7ffb\u8bd1\u7ed3\u679c\u8fdb\u884c\u4e86\u7528\u6237\u8bc4\u4f30\u3002\u57fa\u672c\u4e0a\uff0c\u7528\u6237\u5bf9\u5927\u7ea6\u516d\u5343\u4e2a\u793a\u4f8b\u8fdb\u884c\u4e86\u8bc4\u5206\uff0c\u8bc4\u5206\u8303\u56f4\u4e3a\u4e00\u5230\u56db\u5206\uff0c\u8bc4\u4f30\u7ffb\u8bd1\u7684\u8d28\u91cf\u3002\u7ed3\u679c\u662f\uff0c\u8bb8\u591a\u7ffb\u8bd1\u7ed3\u679c\u5b58\u5728\u566a\u58f0\u3002\u4f46\u6240\u6709\u6a21\u578b\u90fd\u5fc5\u987b\u5e94\u5bf9\u76f8\u540c\u7684\u7ffb\u8bd1\u566a\u58f0\u3002\u4e0d\u8fc7\uff0c\u6a21\u578b\u4e4b\u95f4\u7684\u76f8\u5bf9\u6027\u80fd\u4ecd\u7136\u503c\u5f97\u6ce8\u610f\u3002\u5728\u547d\u540d\u5b9e\u4f53\u8bc6\u522b\u4efb\u52a1\u4e2d\uff0c\u6211\u4eec\u540c\u6837\u53d1\u73b0Kinyabert\u7684\u6027\u80fd\u6700\u4f73\u3002\u5176\u4e2d\uff0c\u540e\u7f00\u5206\u5e03\u6b63\u5219\u5316\u53d8\u4f53\u8868\u73b0\u6700\u597d\u3002\u8fd9\u4e9b\u7ed3\u679c\u540c\u6837\u662f\u5341\u6b21\u5fae\u8c03\u8fd0\u884c\u7684\u5e73\u5747\u503c\u3002\u5728\u65b0\u95fb\u5206\u7c7b\u4efb\u52a1\u4e2d\uff0c\u6211\u4eec\u5f97\u5230\u7684\u7ed3\u679c\u53c2\u5dee\u4e0d\u9f50\u3002\u4e4b\u524d\u7684\u7814\u7a76\u8868\u660e\uff0c\u5bf9\u4e8e\u57fa\u5c3c\u4e9a\u9c81\u5b89\u8fbe\u8bed\u7684\u6587\u672c\u5206\u7c7b\uff0c\u7b80\u5355\u7684\u5173\u952e\u8bcd\u68c0\u6d4b\u5728\u5f88\u5927\u7a0b\u5ea6\u4e0a\u8db3\u4ee5\u89e3\u51b3\u8fd9\u4e00\u7279\u5b9a\u4efb\u52a1\u3002\u56e0\u6b64\uff0c\u4f7f\u7528\u9884\u8bad\u7ec3\u8bed\u8a00\u6a21\u578b\u5728\u8fd9\u4e00\u7279\u5b9a\u65b0\u95fb\u5206\u7c7b\u4efb\u52a1\u4e0a\u7684\u6536\u76ca\u8f83\u5c0f\u3002\u6211\u4eec\u8fd8\u8fdb\u884c\u4e86\u6d88\u878d\u5b9e\u9a8c\uff0c\u4ee5\u67e5\u770b\u662f\u5426\u5b58\u5728\u5176\u4ed6\u7ed3\u6784\u53ef\u4ee5\u63d0\u5347\u6027\u80fd\u3002\u5728GLUE\u57fa\u51c6\u6d4b\u8bd5\u4e2d\uff0c\u6211\u4eec\u53d1\u73b0\u4f7f\u7528\u540e\u7f00\u96c6\u7684\u4e00\u81f4\u6027\u8868\u73b0\u66f4\u4f18\uff0c\u800c\u540e\u7f00\u6982\u7387\u6b63\u5219\u5316\u76ee\u6807\u5219\u5728\u547d\u540d\u5b9e\u4f53\u8bc6\u522b\u4efb\u52a1\u4e0a\u8868\u73b0\u6700\u4f73\u3002\u6b64\u5916\uf